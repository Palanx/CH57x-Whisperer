<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Embedded into the binary (__TEXT,__info_plist) so the unbundled
	     executable shows a proper name in the menu bar. No CFBundleIdentifier
	     on purpose: adding one would change the UserDefaults domain and orphan
	     the stored LED memory. -->
	<key>CFBundleName</key>
	<string>CH57x Whisperer</string>
	<key>CFBundleDisplayName</key>
	<string>CH57x Whisperer</string>
	<key>NSHighResolutionCapable</key>
	<true/>
</dict>
</plist>
